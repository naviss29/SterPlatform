# Copier ce fichier en .env.local et remplir les valeurs
# Les vraies valeurs ne doivent JAMAIS être commitées

###> symfony/framework-bundle ###
APP_ENV=dev
# Générer avec : php -r "echo bin2hex(random_bytes(16));"
APP_SECRET=CHANGE_ME_32_HEX_CHARS
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> app ###
# URL publique de l'application (sans slash final)
APP_URL=http://localhost:8080
# Adresse email expéditeur
APP_FROM_EMAIL=noreply@votre-domaine.fr
###< app ###

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
# Générer avec : openssl rand -hex 32
JWT_PASSPHRASE=CHANGE_ME
###< lexik/jwt-authentication-bundle ###

###> symfony/mailer ###
# Dev local (Mailpit) : smtp://mailer:1025
# Production (ex. Resend) : resend+smtp://resend:YOUR_API_KEY@smtp.resend.com:587
MAILER_DSN=smtp://mailer:1025
###< symfony/mailer ###

###> doctrine/doctrine-bundle ###
# Dev Docker : postgresql://sterplatform:sterplatform@db:5432/sterplatform?serverVersion=16&charset=utf8
# Production : postgresql://USER:PASSWORD@HOST:5432/DB_NAME?serverVersion=16&charset=utf8
DATABASE_URL=postgresql://sterplatform:sterplatform@db:5432/sterplatform?serverVersion=16&charset=utf8
POSTGRES_DB=sterplatform
POSTGRES_USER=sterplatform
POSTGRES_PASSWORD=CHANGE_ME
###< doctrine/doctrine-bundle ###

###> mercure ###
# Générer avec : openssl rand -hex 32
MERCURE_JWT_SECRET=CHANGE_ME
###< mercure ###
