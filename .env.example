# Copier ce fichier en .env.local et remplir les valeurs
# Les vraies valeurs ne doivent JAMAIS être commitées

###> symfony/framework-bundle ###
APP_ENV=dev
# Générer avec : php -r "echo bin2hex(random_bytes(16));"
APP_SECRET=CHANGE_ME_32_HEX_CHARS
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> app ###
# URL publique de l'application (sans slash final)
APP_URL=http://localhost:8080
# Adresse email expéditeur (doit être vérifiée dans Brevo)
APP_FROM_EMAIL=noreply@votre-domaine.fr
# Token partagé avec les apps clientes pour POST /api/email/send
# Générer avec : php -r "echo bin2hex(random_bytes(32));"
APP_TOKEN=CHANGE_ME
###< app ###

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
# Générer avec : openssl rand -hex 32
JWT_PASSPHRASE=CHANGE_ME
###< lexik/jwt-authentication-bundle ###

###> symfony/mailer ###
# Dev local (Mailpit) :
#   MAILER_DSN=smtp://mailer:1025
# Production / staging (Brevo) :
#   1. Brevo → Transactional → SMTP & API → onglet SMTP
#   2. Copier Login (email Brevo) + générer une SMTP Key
#   MAILER_DSN=smtp://LOGIN_BREVO:SMTP_KEY@smtp-relay.brevo.com:587
MAILER_DSN=smtp://mailer:1025
###< symfony/mailer ###

###> doctrine/doctrine-bundle ###
# Dev Docker : postgresql://sterplatform:sterplatform@db:5432/sterplatform?serverVersion=18&charset=utf8
# Production : postgresql://USER:PASSWORD@HOST:5432/DB_NAME?serverVersion=18&charset=utf8
DATABASE_URL=postgresql://sterplatform:sterplatform@db:5432/sterplatform?serverVersion=18&charset=utf8
POSTGRES_DB=sterplatform
POSTGRES_USER=sterplatform
POSTGRES_PASSWORD=CHANGE_ME
###< doctrine/doctrine-bundle ###

###> mercure ###
# Générer avec : openssl rand -hex 32
MERCURE_JWT_SECRET=CHANGE_ME
###< mercure ###
