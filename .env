# In all environments, the following files are loaded if they exist,
# the latter taking precedence over the former:
#
#  * .env                contains default values for the environment variables needed by the app
#  * .env.local          uncommitted file with local overrides
#  * .env.$APP_ENV       committed environment-specific defaults
#  * .env.$APP_ENV.local uncommitted environment-specific overrides
#
# Real environment variables win over .env files.
#
# DO NOT DEFINE PRODUCTION SECRETS IN THIS FILE NOR IN ANY OTHER COMMITTED FILES.
# https://symfony.com/doc/current/configuration/secrets.html

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=86ef761da6ef3a3592114f6813e2dfbafb73550da102645b393caa190016c94f
###< lexik/jwt-authentication-bundle ###

###> symfony/mailer ###
MAILER_DSN=smtp://mailer:1025
###< symfony/mailer ###

###> app ###
APP_URL=http://localhost:8080
APP_FROM_EMAIL=noreply@sterplatform.local
# Token applicatif partagé avec les apps clientes (DartsOpen, FestManager)
# Générer avec : php -r "echo bin2hex(random_bytes(32));"
APP_TOKEN=change_me_in_prod
###< app ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="postgresql://sterplatform:sterplatform@db:5432/sterplatform?serverVersion=18&charset=utf8"
POSTGRES_DB=sterplatform
POSTGRES_USER=sterplatform
POSTGRES_PASSWORD=sterplatform
###< doctrine/doctrine-bundle ###

###> mercure ###
MERCURE_JWT_SECRET=sterplatform_mercure_secret_key_32ch
# URL interne Docker (backend → hub Mercure)
MERCURE_HUB_URL=http://mercure/.well-known/mercure
MERCURE_HUB_INTERNAL_URL=http://mercure/.well-known/mercure
# URL publique (navigateur → hub Mercure)
MERCURE_HUB_PUBLIC_URL=http://localhost:9090/.well-known/mercure
###< mercure ###
